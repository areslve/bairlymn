@model EditProfileViewModel
@{
    ViewData["Title"] = "Профайл засах";
}

<div class="bg-light py-3 border-bottom mb-4">
    <div class="container">
        <nav>
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item">
                    <a asp-controller="Profile" asp-action="Index"
                       class="text-success">Профайл</a>
                </li>
                <li class="breadcrumb-item active">Засах</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container pb-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header p-4"
                     style="background:linear-gradient(135deg,#166534,#16a34a)">
                    <h4 class="fw-700 text-white mb-0">
                        <i class="bi bi-person-gear me-2"></i>Профайл засах
                    </h4>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Edit" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()

                        <!-- Avatar section -->
                        <div class="text-center mb-5">
                            <div class="position-relative d-inline-block">
                                <img src="@(Model.CurrentAvatarPath ?? "/img/default-avatar.svg")"
                                     class="rounded-circle shadow"
                                     width="120" height="120"
                                     style="object-fit:cover;
                                border:4px solid #16a34a"
                                     id="avatarPreview"
                                     onerror="this.src='/img/default-avatar.svg'" />

                                <label for="avatarInput"
                                       class="position-absolute bottom-0 end-0
                                    btn btn-success rounded-circle
                                    d-flex align-items-center
                                    justify-content-center"
                                       style="width:36px;height:36px;
                                    cursor:pointer;
                                    box-shadow:0 2px 8px rgba(0,0,0,.2)">
                                    <i class="bi bi-camera-fill" style="font-size:14px"></i>
                                </label>
                                <input asp-for="AvatarFile"
                                       id="avatarInput"
                                       type="file"
                                       accept="image/jpeg,image/png,image/webp"
                                       class="d-none"
                                       onchange="prevAvatar(this)" />
                            </div>
                            <div class="mt-2">
                                <span asp-validation-for="AvatarFile"
                                      class="text-danger small"></span>
                            </div>
                            <p class="text-muted small mt-1 mb-0">
                                .jpg .png .webp — дээд тал нь 10MB
                            </p>
                        </div>

                        <!-- Name fields -->
                        <div class="row g-3 mb-3">
                            <div class="col-6">
                                <label asp-for="FirstName" class="form-label fw-600">Нэр</label>
                                <input asp-for="FirstName" class="form-control rounded-3"
                                       placeholder="Болд" />
                                <span asp-validation-for="FirstName"
                                      class="text-danger small mt-1 d-block"></span>
                            </div>
                            <div class="col-6">
                                <label asp-for="LastName" class="form-label fw-600">Овог</label>
                                <input asp-for="LastName" class="form-control rounded-3"
                                       placeholder="Батаа" />
                                <span asp-validation-for="LastName"
                                      class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>

                        <!-- Phone -->
                        <div class="mb-3">
                            <label asp-for="PhoneNumber" class="form-label fw-600">
                                Утасны дугаар
                            </label>
                            <div class="input-group">
                                <span class="input-group-text bg-light">
                                    <i class="bi bi-telephone text-muted"></i>
                                </span>
                                <input asp-for="PhoneNumber"
                                       class="form-control rounded-end-3"
                                       placeholder="+976 9900 0000" />
                            </div>
                            <span asp-validation-for="PhoneNumber"
                                  class="text-danger small mt-1 d-block"></span>
                        </div>

                        <!-- Bio -->
                        <div class="mb-4">
                            <label asp-for="Bio" class="form-label fw-600">
                                Танилцуулга
                                <small class="text-muted fw-400">(заавал биш)</small>
                            </label>
                            <textarea asp-for="Bio"
                                      class="form-control rounded-3"
                                      rows="3"
                                      placeholder="Өөрийгөө товч танилцуул..."
                                      maxlength="500"></textarea>
                            <div class="d-flex justify-content-between mt-1">
                                <span asp-validation-for="Bio"
                                      class="text-danger small"></span>
                                <small class="text-muted" id="bioCount">0/500</small>
                            </div>
                        </div>

                        <!-- Buttons -->
                        <div class="d-flex gap-3 justify-content-end">
                            <a asp-action="Index"
                                   class="btn btn-light rounded-pill px-4 fw-500">
                                Болих
                            </a>
                            <button type="submit"
                                    class="btn btn-success rounded-pill px-5 fw-700">
                                <i class="bi bi-check me-2"></i>Хадгалах
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Change password card -->
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden mt-4">
                <div class="card-body p-4">
                    <h5 class="fw-700 mb-1">
                        <i class="bi bi-shield-lock me-2 text-success"></i>
                        Нууц үг солих
                    </h5>
                    <p class="text-muted small mb-3">
                        Нууц үгээ Identity-н стандарт хуудсаар солино уу
                    </p>
                    <a asp-area="Identity" asp-page="/Account/Manage/ChangePassword"
                           class="btn btn-outline-success rounded-pill px-4 fw-600">
                        <i class="bi bi-key me-2"></i>Нууц үг солих
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function prevAvatar(input) {
            if (!input.files?.[0]) return;
            const reader = new FileReader();
            reader.onload = e => {
                document.getElementById('avatarPreview').src = e.target.result;
            };
            reader.readAsDataURL(input.files[0]);
        }

        // Bio character counter
        const bioInput = document.querySelector('textarea[name="Bio"]');
        const bioCount = document.getElementById('bioCount');
        if (bioInput && bioCount) {
            const update = () => bioCount.textContent = `${bioInput.value.length}/500`;
            bioInput.addEventListener('input', update);
            update();
        }
    </script>
}