@model ChatViewModel
@{
    ViewData["Title"] = "Чат";
    Layout = "_ChatLayout";   // ← тусгай layout ашиглана (footer байхгүй)
    var conv = Model.ActiveConversation;
    var other = conv?.InitiatorId == Model.CurrentUserId
        ? conv?.Participant : conv?.Initiator;
    var isAdmin = User.IsInRole("Admin");
    var pendingRequest = isAdmin && other != null
        ? ViewBag.PendingAgentRequest as BairlyMN.Data.Entities.AgentRequest : null;
    var otherIsAgent = other?.HasActiveAgent == true;
}

<div class="chat-shell @(conv != null ? "conv-open" : "")">

    <!-- ── Зүүн: Яриануудын жагсаалт ─────────────────────────── -->
    <aside class="chat-sidebar">
        <div class="chat-sidebar-header">
            <div class="d-flex align-items-center gap-2">
                <i class="bi bi-chat-dots-fill text-success"></i>
                <span class="fw-700">Чат</span>
                @if (Model.UnreadCount > 0)
                {
                    <span class="badge bg-danger rounded-pill"
                          style="font-size:.65rem;padding:3px 7px">@Model.UnreadCount</span>
                }
            </div>
            <a asp-controller="Home" asp-action="Index"
                   class="chat-icon-btn" title="Нүүр">
                <i class="bi bi-house"></i>
            </a>
        </div>

        <div class="chat-conv-list">
            @if (!Model.Conversations.Any())
            {
                <div class="chat-empty-list">
                    <i class="bi bi-chat-square opacity-40 fs-2"></i>
                    <p class="small fw-500 mt-2 mb-1">Яриа байхгүй</p>
                    <a asp-controller="Listings" asp-action="Index"
                           class="btn btn-sm btn-success rounded-pill px-3">
                        Зарууд харах
                    </a>
                </div>
            }
            @foreach (var c in Model.Conversations)
            {
                var o = c.InitiatorId == Model.CurrentUserId ? c.Participant : c.Initiator;
                var last = c.Messages?.OrderByDescending(m => m.SentAt).FirstOrDefault();
                var isActive = conv?.Id == c.Id;
                var hasUnread = last != null
                    && last.SenderId != Model.CurrentUserId
                    && last.Status != BairlyMN.Domain.Enums.MessageStatus.Read;

                <a asp-controller="Chat" asp-action="Conversation"
                       asp-route-id="@c.Id"
                       class="chat-conv-item @(isActive ? "active" : "")">
                    <div class="position-relative flex-shrink-0">
                        <img src="@(o?.AvatarPath ?? "/img/default-avatar.svg")"
                             class="rounded-circle"
                             width="44" height="44"
                             style="object-fit:cover"
                             onerror="this.src='/img/default-avatar.svg'" />
                        @if (hasUnread)
                        {
                            <span class="chat-unread-dot"></span>
                        }
                    </div>
                    <div class="flex-grow-1 overflow-hidden">
                        <div class="d-flex justify-content-between align-items-baseline">
                            <div class="d-flex align-items-center gap-1">
                                <span class="fw-600 text-dark" style="font-size:.88rem">
                                    @o?.DisplayName
                                </span>
                                @if (o?.HasActiveAgent == true)
                                {
                                    <i class="bi bi-patch-check-fill text-success"
                                       style="font-size:.65rem"></i>
                                }
                            </div>
                            <span class="text-muted flex-shrink-0" style="font-size:.7rem">
                                @c.LastMessageAt.ToString("HH:mm")
                            </span>
                        </div>
                        @if (c.Listing != null)
                        {
                            <div class="text-success text-truncate" style="font-size:.72rem">
                                <i class="bi bi-house me-1"></i>
                                @(c.Listing.Title?.Length > 28
                                    ? c.Listing.Title[..28] + "…" : c.Listing.Title)
                            </div>
                        }
                        @if (last != null)
                        {
                            <p class="mb-0 text-truncate"
                                   style="font-size:.78rem;
                                color:@(hasUnread ? "#1e293b" : "#94a3b8");
                                font-weight:@(hasUnread ? "600" : "400")">
                                @(last.SenderId == Model.CurrentUserId ? "Та: " : "")
                                @(last.Content.Length > 32
                                    ? last.Content[..32] + "…" : last.Content)
                            </p>
                        }
                    </div>
                </a>
            }
        </div>
    </aside>

    <!-- ── Баруун: Чатын цонх ─────────────────────────────────── -->
    <main class="chat-main">

        @if (conv != null)
        {
            <!-- Header -->
            <!-- chat-main-header дотор хамгийн эхэнд нэмэх -->
            <button class="d-md-none chat-icon-btn me-1"
                    onclick="goBackToList()"
                    title="Буцах">
                <i class="bi bi-arrow-left"></i>
            </button>
            <div class="chat-main-header">
                <div class="d-flex align-items-center gap-3 flex-grow-1 overflow-hidden">
                    <img src="@(other?.AvatarPath ?? "/img/default-avatar.svg")"
                         class="rounded-circle flex-shrink-0"
                         width="40" height="40"
                         style="object-fit:cover"
                         onerror="this.src='/img/default-avatar.svg'" />
                    <div class="overflow-hidden">
                        <div class="d-flex align-items-center gap-2">
                            <span class="fw-700 text-truncate">@other?.DisplayName</span>
                            @if (otherIsAgent)
                            {
                                <span class="agent-badge flex-shrink-0">
                                    <i class="bi bi-patch-check-fill"
                                       style="font-size:.6rem"></i>Агент
                                </span>
                            }
                        </div>
                        @if (conv.Listing != null)
                        {
                            <a asp-controller="Listings" asp-action="Details"
                                   asp-route-id="@conv.Listing.Id"
                                   class="text-success text-decoration-none text-truncate d-block"
                                   style="font-size:.78rem">
                                <i class="bi bi-house me-1"></i>@conv.Listing.Title
                            </a>
                        }
                    </div>
                </div>

                <!-- Admin товчнууд -->
                @if (isAdmin && other != null)
                {
                    <div class="d-flex gap-2 flex-shrink-0 align-items-center">
                        @if (pendingRequest != null)
                        {
                            <span class="badge rounded-pill"
                                  style="background:#fef3c7;color:#92400e;font-size:.7rem">
                                <i class="bi bi-hourglass-split me-1"></i>Хүсэлт
                            </span>
                            <a asp-controller="Admin" asp-action="GrantAgent"
                                   asp-route-userId="@other.Id"
                                   class="btn btn-sm rounded-pill fw-600"
                                   style="background:#dcfce7;color:#166534;
                                border:1px solid #bbf7d0;font-size:.75rem">
                                <i class="bi bi-patch-check me-1"></i>Агент болгох
                            </a>
                            <form asp-controller="Admin" asp-action="RejectAgentRequest"
                                  asp-route-requestId="@pendingRequest.Id"
                                  method="post"
                                  onsubmit="return confirm('Татгалзах уу?')">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm rounded-pill fw-600"
                                        style="background:#fee2e2;color:#dc2626;
                                    border:1px solid #fecaca;font-size:.75rem">
                                    <i class="bi bi-x-circle me-1"></i>Татгалзах
                                </button>
                            </form>
                        }
                        else if (otherIsAgent)
                        {
                            <span class="text-muted small">
                                @other.AgentUntil?.ToString("yyyy/MM/dd") хүртэл
                            </span>
                            <form asp-controller="Admin" asp-action="RevokeAgent"
                                  asp-route-userId="@other.Id"
                                  method="post"
                                  onsubmit="return confirm('Эрх хасах уу?')">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm rounded-pill fw-600"
                                        style="background:#fee2e2;color:#dc2626;
                                    border:1px solid #fecaca;font-size:.75rem">
                                    <i class="bi bi-x-circle me-1"></i>Эрх хасах
                                </button>
                            </form>
                        }
                        else
                        {
                            <a asp-controller="Admin" asp-action="GrantAgent"
                                   asp-route-userId="@other.Id"
                                   class="btn btn-sm rounded-pill fw-600"
                                   style="background:#dcfce7;color:#166534;
                                border:1px solid #bbf7d0;font-size:.75rem">
                                <i class="bi bi-patch-check me-1"></i>Агент болгох
                            </a>
                        }
                    </div>
                }

                @if (conv.Listing?.Images?.FirstOrDefault()?.ImagePath is string thumb)
                {
                    <a asp-controller="Listings" asp-action="Details"
                           asp-route-id="@conv.Listing.Id"
                           class="flex-shrink-0 d-none d-md-block">
                        <img src="@thumb" class="rounded-3"
                             width="52" height="40"
                             style="object-fit:cover"
                             onerror="this.src='/img/no-image.svg'" />
                    </a>
                }
            </div>

            <!-- Мессежүүд -->
            <div id="msgList" class="chat-messages">
                @{
                    DateTime? lastDate = null;
                }
                @foreach (var msg in Model.Messages)
                {
                    var isOwn = msg.SenderId == Model.CurrentUserId;
                    var msgDate = msg.SentAt.Date;
                    if (lastDate != msgDate)
                    {
                        lastDate = msgDate;
                        <div class="chat-date-divider">
                            <span>
                                @(msgDate == DateTime.UtcNow.Date ? "Өнөөдөр"
                                                : msgDate == DateTime.UtcNow.Date.AddDays(-1) ? "Өчигдөр"
                                                : msgDate.ToString("yyyy/MM/dd"))
                            </span>
                        </div>
                    }

                    <div class="chat-msg-row @(isOwn ? "own" : "other")">
                        @if (!isOwn)
                        {
                            <img src="@(msg.Sender?.AvatarPath ?? "/img/default-avatar.svg")"
                                 class="chat-avatar"
                                 onerror="this.src='/img/default-avatar.svg'" />
                        }
                        <div class="chat-bubble @(isOwn ? "own" : "other")">
                            @if (!string.IsNullOrEmpty(msg.ImagePath))
                            {
                                <a href="@msg.ImagePath" target="_blank">
                                    <img src="@msg.ImagePath"
                                         style="max-width:220px;max-height:200px;
                                    border-radius:10px;display:block;
                                    margin-bottom:6px"
                                         onerror="this.style.display='none'" />
                                </a>
                            }
                            @if (!string.IsNullOrWhiteSpace(msg.Content))
                            {
                                <p class="mb-0" style="white-space:pre-wrap">@msg.Content</p>
                            }
                            <div class="chat-bubble-meta @(isOwn ? "own" : "")">
                                <span>@msg.SentAt.ToString("HH:mm")</span>
                                @if (isOwn)
                                {
                                    <span class="msg-status">
                                        @if (msg.Status == BairlyMN.Domain.Enums.MessageStatus.Read)
                                        {
                                            <i class="bi bi-check2-all"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-check2"></i>
                                        }
                                    </span>
                                }
                            </div>
                        </div>
                        @if (isOwn)
                        {
                            <img src="@(Model.Conversations
                                                                                                     .FirstOrDefault(c => c.Id == conv.Id)
                                                                                                     ?.Initiator?.AvatarPath ?? "/img/default-avatar.svg")"
                                 class="chat-avatar d-none d-md-block"
                                 onerror="this.src='/img/default-avatar.svg'" />
                        }
                    </div>
                }
                <div id="anchor"></div>
            </div>

            <!-- Зураг preview -->
            <div id="imgPreviewBar"
                 style="display:none;padding:8px 16px;background:#f0fdf4;
                border-top:1px solid #dcfce7">
                <div class="d-flex align-items-center gap-2">
                    <img id="imgPreviewThumb"
                         style="height:56px;border-radius:8px;object-fit:cover" />
                    <span id="imgPreviewName"
                          class="text-muted small text-truncate flex-grow-1"></span>
                    <button type="button" onclick="removeImg()"
                            class="btn btn-sm btn-light rounded-circle"
                            style="width:28px;height:28px;padding:0">
                        <i class="bi bi-x"></i>
                    </button>
                </div>
            </div>

            <!-- Input -->
            <div class="chat-input-area">
                <input type="file" id="imgFileInput" accept="image/*"
                       style="display:none" onchange="onImgSelect(event)" />
                <button class="chat-icon-btn" onclick="document.getElementById('imgFileInput').click()"
                        title="Зураг илгээх" type="button">
                    <i class="bi bi-image text-success"></i>
                </button>
                <textarea id="msgInput"
                          placeholder="Мессеж бичих..."
                          rows="1"
                          onkeydown="onEnter(event)"></textarea>
                <button id="sendBtn" class="chat-send-btn" onclick="send()">
                    <i class="bi bi-send-fill"></i>
                </button>
            </div>
            <div class="chat-input-hint">
                <i class="bi bi-info-circle me-1"></i>
                Enter дарж илгээх · Shift+Enter шинэ мөр
            </div>
        }
        else
        {
            <div class="chat-empty-state">
                <div class="chat-empty-icon">
                    <i class="bi bi-chat-heart-fill text-success fs-2"></i>
                </div>
                <h5 class="fw-700 mb-1">Яриа сонгоно уу</h5>
                <p class="text-muted small mb-3">
                    Зүүн талаас яриа сонгох эсвэл зарын дэлгэрэнгүйд орж эхлүүлнэ үү
                </p>
                <a asp-controller="Listings" asp-action="Index"
                       class="btn btn-success rounded-pill px-4 fw-600">
                    <i class="bi bi-search me-2"></i>Зарууд харах
                </a>
            </div>
        }
    </main>
</div>

@section Scripts {
    <script>
        const ME      = '@Model.CurrentUserId';
        const CONV_ID = @(conv?.Id.ToString() ?? "0");

        const conn = new signalR.HubConnectionBuilder()
            .withUrl('/hubs/chat')
            .withAutomaticReconnect([0,1000,3000,5000])
            .build();

        conn.onreconnecting(() => showToast('Дахин холбогдож байна...','warning'));
        conn.onreconnected(()  => showToast('Холбогдлоо','success'));
        conn.onclose(()        => showToast('Холболт тасарлаа','danger'));

        conn.on('ReceiveMessage', msg => {
            appendMsg(msg);
            scrollDown();
            if (msg.senderId !== ME && CONV_ID > 0)
                conn.invoke('MarkAsRead', CONV_ID).catch(()=>{});
        });

        conn.on('MessagesRead', (convId, userId) => {
            if (userId !== ME)
                document.querySelectorAll('.msg-status')
                        .forEach(el => el.innerHTML = '<i class="bi bi-check2-all"></i>');
        });

        async function start() {
            try {
                await conn.start();
                if (CONV_ID > 0) {
                    await conn.invoke('JoinConversation', CONV_ID);
                    scrollDown();
                }
            } catch(e) { setTimeout(start, 3000); }
        }

        function appendMsg(msg) {
            const anchor = document.getElementById('anchor');
            if (!anchor) return;
            const isOwn = msg.senderId === ME;
            const d = document.createElement('div');
            d.className = `chat-msg-row ${isOwn?'own':'other'}`;

            const imgHtml = msg.imageUrl
                ? `<a href="${msg.imageUrl}" target="_blank">
                     <img src="${msg.imageUrl}"
                          style="max-width:220px;max-height:200px;border-radius:10px;
                                 display:block;margin-bottom:6px"
                          onerror="this.style.display='none'" />
                   </a>` : '';
            const textHtml = msg.content
                ? `<p class="mb-0" style="white-space:pre-wrap">${esc(msg.content)}</p>` : '';

            d.innerHTML = `
                ${!isOwn ? `<img src="${msg.senderAvatar||'/img/default-avatar.svg'}"
                                 class="chat-avatar"
                                 onerror="this.src='/img/default-avatar.svg'" />` : ''}
                <div class="chat-bubble ${isOwn?'own':'other'}">
                    ${imgHtml}${textHtml}
                    <div class="chat-bubble-meta ${isOwn?'own':''}">
                        <span>${msg.sentAt}</span>
                        ${isOwn?'<span class="msg-status"><i class="bi bi-check2"></i></span>':''}
                    </div>
                </div>
                ${isOwn ? `<img src="${msg.senderAvatar||'/img/default-avatar.svg'}"
                                class="chat-avatar d-none d-md-block"
                                onerror="this.src='/img/default-avatar.svg'" />` : ''}`;
            anchor.before(d);
        }

        function esc(s) {
            return s.replace(/&/g,'&amp;').replace(/</g,'&lt;')
                    .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
        }
        function scrollDown() {
            document.getElementById('anchor')?.scrollIntoView({behavior:'smooth'});
        }
                // Мобайл: sidebar руу буцах
        function goBackToList() {
            const shell = document.querySelector('.chat-shell');
            if (shell) {
                shell.classList.remove('conv-open');
            }
        }

        /* ── Зураг upload ───────────────────────────── */
        let selectedFile = null;

        function onImgSelect(e) {
            const file = e.target.files[0];
            if (!file) return;
            selectedFile = file;
            const reader = new FileReader();
            reader.onload = ev => {
                document.getElementById('imgPreviewThumb').src = ev.target.result;
                document.getElementById('imgPreviewName').textContent = file.name;
                document.getElementById('imgPreviewBar').style.display = 'block';
            };
            reader.readAsDataURL(file);
        }

        function removeImg() {
            selectedFile = null;
            document.getElementById('imgFileInput').value = '';
            document.getElementById('imgPreviewBar').style.display = 'none';
        }

        /* ── Илгээх ─────────────────────────────────── */
        let isSending = false;

        async function send() {
            if (isSending) return;
            const input = document.getElementById('msgInput');
            const text  = input.value.trim();
            if (!text && !selectedFile) return;
            if (!CONV_ID) return;

            isSending = true;
            const btn = document.getElementById('sendBtn');
            btn.innerHTML = '<div class="spinner-border spinner-border-sm"></div>';
            btn.disabled  = true;

            try {
                if (selectedFile) {
                    // Зураг + текст upload via HTTP
                    const fd = new FormData();
                    fd.append('conversationId', CONV_ID);
                    fd.append('content', text);
                    fd.append('image', selectedFile);
                    const r = await fetch('/Chat/SendWithImage', {
                        method: 'POST',
                        body: fd,
                        headers: {
                            'RequestVerificationToken':
                                document.querySelector('[name=__RequestVerificationToken]')?.value || ''
                        }
                    });
                    if (!r.ok) throw new Error('Upload failed');
                    removeImg();
                } else {
                    await conn.invoke('SendMessage', CONV_ID, text);
                }
                input.value        = '';
                input.style.height = 'auto';
            } catch(e) {
                input.value = text;
                showToast('Илгээхэд алдаа гарлаа','danger');
            } finally {
                isSending     = false;
                btn.innerHTML = '<i class="bi bi-send-fill"></i>';
                btn.disabled  = false;
                input.focus();
            }
        }

        function onEnter(e) {
            if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); send(); }
        }

        document.getElementById('msgInput')?.addEventListener('input', function() {
            this.style.height = 'auto';
            this.style.height = Math.min(this.scrollHeight, 150) + 'px';
        });

        start().catch(console.error);
    </script>
}