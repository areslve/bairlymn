@model BairlyMN.Data.Entities.Listing
@{
    var thumb = Model.Images?.OrderBy(i => i.SortOrder).FirstOrDefault()?.ImagePath
                 ?? "/img/no-image.svg";
    var isSale = Model.TransactionType == TransactionType.Sale;

    var typeLabel = Model.PropertyType switch
    {
        PropertyType.Apartment => "Орон сууц",
        PropertyType.House => "Байшин",
        PropertyType.Land => "Газар",
        PropertyType.Office => "Оффис",
        PropertyType.Warehouse => "Агуулах",
        _ => "Бусад"
    };

    var rooms = Model.ApartmentDetails?.Rooms ?? Model.HouseDetails?.Rooms;
    var floor = Model.ApartmentDetails?.Floor;
    var totalFloors = Model.ApartmentDetails?.TotalFloors;

    // Агент эрхтэй хэрэглэгчийн зар эсэх
    var isAgentListing = Model.User?.HasActiveAgent == true;
}

<div class="listing-card card border-0 rounded-4 overflow-hidden h-100
    @(isAgentListing ? "is-agent" : "")">

    <!-- Image -->
    <div class="listing-card-img position-relative overflow-hidden">
        <a asp-controller="Listings" asp-action="Details" asp-route-id="@Model.Id"
               class="d-block">
            <img src="@thumb"
                 class="w-100"
                 alt="@Model.Title"
                 style="height:210px;object-fit:cover"
                 loading="lazy"
                 onerror="this.src='/img/no-image.svg'" />
        </a>

        <!-- Badges top-left -->
        <div class="position-absolute top-0 start-0 p-2 d-flex flex-column gap-1">

            @if (Model.Status != BairlyMN.Domain.Enums.ListingStatus.Active)
            {
                <span class="badge rounded-pill fw-600"
                      style="background:rgba(0,0,0,.6);color:white;font-size:.7rem">
                    @(Model.Status switch
                    {
                        BairlyMN.Domain.Enums.ListingStatus.Inactive => "Идэвхгүй",
                        BairlyMN.Domain.Enums.ListingStatus.Sold => "Зарагдсан",
                        BairlyMN.Domain.Enums.ListingStatus.Rented => "Түрээслэгдсэн",
                        _ => "Хүлээгдэж байна"
                    })
                </span>
            }

            <span class="badge rounded-pill fw-600"
                  style="@(isSale
                                                        ? "background:#16a34a;color:white"
                                                        : "background:#2563eb;color:white")
                font-size:.72rem">
                @(isSale ? "Худалдах" : "Түрээслэх")
            </span>

            @if (Model.IsPromoted)
            {
                <span class="badge rounded-pill fw-600"
                      style="background:#f59e0b;color:white;font-size:.72rem">
                    <i class="bi bi-star-fill me-1"></i>Онцлох
                </span>
            }
        </div>

        <!-- View count top-right -->
        <div class="position-absolute top-0 end-0 p-2">
            <span class="badge rounded-pill fw-500"
                  style="background:rgba(0,0,0,.45);color:white;
                font-size:.7rem;backdrop-filter:blur(4px)">
                <i class="bi bi-eye me-1"></i>@Model.ViewCount
            </span>
        </div>

        <!-- Image count bottom-right -->
        @if (Model.Images?.Count > 1)
        {
            <div class="position-absolute bottom-0 end-0 p-2">
                <span class="badge rounded-pill"
                      style="background:rgba(0,0,0,.45);color:white;
                    font-size:.7rem;backdrop-filter:blur(4px)">
                    <i class="bi bi-images me-1"></i>@Model.Images.Count
                </span>
            </div>
        }
    </div>

    <!-- Body -->
    <div class="card-body p-3 d-flex flex-column">

        <!-- Type + Agent badge -->
        <div class="mb-2 d-flex align-items-center gap-2 flex-wrap">
            <span class="badge rounded-pill fw-500"
                  style="background:#f0fdf4;color:#166534;font-size:.72rem">
                @typeLabel
            </span>
            @if (isAgentListing)
            {
                <span class="agent-badge">
                    <i class="bi bi-patch-check-fill" style="font-size:.6rem"></i>Агент
                </span>
            }
        </div>

        <!-- Title -->
        <h6 class="fw-700 mb-1 lh-sm" style="font-size:.9rem">
            <a asp-controller="Listings" asp-action="Details" asp-route-id="@Model.Id"
                   class="text-decoration-none text-dark stretched-link-inner"
                   style="display:-webkit-box;-webkit-line-clamp:2;
                -webkit-box-orient:vertical;overflow:hidden">
                @Model.Title
            </a>
        </h6>

        <!-- Location -->
        @if (!string.IsNullOrEmpty(Model.Address) || Model.LocationNode != null)
        {
            <p class="text-muted mb-2 text-truncate" style="font-size:.8rem">
                <i class="bi bi-geo-alt me-1"></i>
                @(Model.Address ?? Model.LocationNode?.Name)
            </p>
        }

        <!-- Quick specs -->
        @if (rooms.HasValue || Model.Area.HasValue || floor.HasValue)
        {
            <div class="d-flex gap-3 mb-2 flex-wrap">
                @if (rooms.HasValue)
                {
                    <span class="text-muted" style="font-size:.78rem">
                        <i class="bi bi-door-open me-1 text-success"></i>@rooms өрөө
                    </span>
                }
                @if (Model.Area.HasValue)
                {
                    <span class="text-muted" style="font-size:.78rem">
                        <i class="bi bi-rulers me-1 text-success"></i>@Model.Area м²
                    </span>
                }
                @if (floor.HasValue)
                {
                    <span class="text-muted" style="font-size:.78rem">
                        <i class="bi bi-layers me-1 text-success"></i>
                        @floor@(totalFloors.HasValue ? $"/{totalFloors}" : "")-р давхар
                    </span>
                }
            </div>
        }

        <div class="mt-auto">
            <div class="d-flex justify-content-between align-items-end">
                <div>
                    <div class="fw-800 text-success"
                         style="font-size:1.15rem;letter-spacing:-.5px"
                         title="@Model.Price.ToString("N0") ₮">
                        @FormatPrice(Model.Price) ₮
                    </div>
                    @if (!isSale)
                    {
                        <small class="text-muted">/сар</small>
                    }
                    @if (Model.Area.HasValue && Model.Price > 0 && isSale)
                    {
                        <div class="text-muted" style="font-size:.72rem">
                            @((Model.Price / Model.Area.Value).ToString("N0")) ₮/м²
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <div class="card-footer bg-transparent border-top px-3 pb-3 pt-2">
        <div class="d-flex align-items-center justify-content-between">
            <div class="d-flex align-items-center gap-2">
                <img src="@(Model.User?.AvatarPath ?? "/img/default-avatar.svg")"
                     class="rounded-circle flex-shrink-0"
                     width="24" height="24"
                     style="object-fit:cover"
                     onerror="this.src='/img/default-avatar.svg'" />
                <span class="text-muted text-truncate"
                      style="font-size:.78rem;max-width:100px">
                    @Model.User?.DisplayName
                </span>
                @if (isAgentListing)
                {
                    <i class="bi bi-patch-check-fill text-success"
                       style="font-size:.75rem" title="Агент"></i>
                }
            </div>
            <span class="text-muted" style="font-size:.72rem">
                @GetTimeAgo(Model.CreatedAt)
            </span>
        </div>
    </div>
</div>

@functions {
    string GetTimeAgo(DateTime date)
    {
        var diff = DateTime.UtcNow - date;
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes} мин өмнө";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours} цаг өмнө";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays} өдөр өмнө";
        if (diff.TotalDays < 30) return $"{(int)(diff.TotalDays / 7)} 7 хоног өмнө";
        return date.ToString("MM/dd");
    }
    string FormatPrice(decimal price)
    {
        if (price >= 1_000_000_000) return $"{price / 1_000_000_000:0.#} тэрбум";   // Тэрбум
        if (price >= 1_000_000) return $"{price / 1_000_000:0.#} сая";        // Сая
        if (price >= 1_000) return $"{price / 1_000:0.#} мянга";            // Мянга
        return price.ToString("N0");
    }
}
