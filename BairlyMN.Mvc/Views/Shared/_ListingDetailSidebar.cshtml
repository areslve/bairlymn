@model ListingDetailViewModel
@{
    var l = Model.Listing;
    var isSale = l.TransactionType == BairlyMN.Domain.Enums.TransactionType.Sale;
}

<div class="card border-0 shadow-sm rounded-3 overflow-hidden">

    <!-- Price header (sidebar дотор) -->

    <div class="p-3">
        <!-- Owner/edit actions -->
        @if (Model.IsOwner || Model.IsAdmin)
        {
            <div class="d-flex gap-2 mb-3">
                <a asp-controller="Listings" asp-action="Edit" asp-route-id="@l.Id"
                       class="btn btn-outline-primary flex-fill rounded-3 fw-600">
                    <i class="bi bi-pencil me-1"></i>Засах
                </a>
                <button class="btn btn-outline-danger rounded-3"
                        onclick="confirmDelete(@l.Id)"
                        type="button">
                    <i class="bi bi-trash"></i>
                </button>
            </div>
        }
        else if (User?.Identity?.IsAuthenticated == true)
        {
            <button id="favBtn"
                    type="button"
                    class="btn @(Model.IsFavorited ? "btn-warning" : "btn-outline-warning")
                w-100 rounded-3 mb-3 fw-600"
                    onclick="toggleFav(@l.Id)">
                <i class="bi @(Model.IsFavorited ? "bi-bookmark-fill" : "bi-bookmark") me-2"></i>
                @(Model.IsFavorited ? "Хадгалагдсан" : "Хадгалах")
            </button>
        }

        <!-- Owner info -->
        <div class="fw-600 small text-muted text-uppercase mb-2" style="font-size:.68rem">
            Зарын эзэн
        </div>
        <div class="d-flex align-items-center gap-3 mb-3">
            <img src="@(l.User?.AvatarPath ?? "/img/default-avatar.svg")"
                 class="rounded-circle flex-shrink-0"
                 width="48" height="48"
                 style="object-fit:cover;border:2px solid #e2e8f0"
                 onerror="this.src='/img/default-avatar.svg'" />
            <div>
                <div class="fw-700">@l.User?.DisplayName</div>
                <div class="text-muted" style="font-size:.75rem">
                    @l.CreatedAt.ToString("yyyy/MM/dd") -нд нэмсэн
                </div>
            </div>
        </div>

        <!-- Phone -->
        @if (!string.IsNullOrEmpty(l.User?.PhoneNumber))
        {
            <a href="tel:@l.User.PhoneNumber"
                   class="btn btn-light w-100 rounded-3 mb-2 fw-600 text-start d-flex align-items-center gap-2">
                <i class="bi bi-telephone-fill text-success"></i>
                @l.User.PhoneNumber
            </a>
        }

        <!-- Chat -->
        @if (User?.Identity?.IsAuthenticated == true && !Model.IsOwner)
        {
            <form asp-controller="Chat" asp-action="Start" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="participantId" value="@l.UserId" />
                <input type="hidden" name="listingId" value="@l.Id" />
                <button type="submit"
                        class="btn btn-success w-100 rounded-3 fw-700 py-2 mb-2">
                    <i class="bi bi-chat-dots me-2"></i>Холбоо барих
                </button>
            </form>
        }
        else if (User?.Identity?.IsAuthenticated != true)
        {
            <a asp-controller="Account" asp-action="Login"
                   class="btn btn-success w-100 rounded-3 fw-700 py-2 mb-2">
                <i class="bi bi-chat-dots me-2"></i>Холбоо барих
            </a>
        }

        <!-- Share -->
        <button type="button"
                class="btn btn-light w-100 rounded-3 small fw-500"
                onclick="copyLink()">
            <i class="bi bi-link-45deg me-1"></i>Холбоос хуулах
        </button>
    </div>
</div>