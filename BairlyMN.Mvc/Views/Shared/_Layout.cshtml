<!DOCTYPE html>
<html lang="mn">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    @{
        var pageTitle = ViewData["Title"]?.ToString();
        var pageDescription = ViewData["Description"]?.ToString()
                              ?? "Монголын хамгийн том үл хөдлөх хөрөнгийн онлайн зах зээл. Орон сууц, байшин, газар худалдах, түрээслэх.";
        var pageImage = ViewData["OgImage"]?.ToString() ?? "/img/hero-default.svg";
        var fullTitle = pageTitle != null
                              ? $"{pageTitle} — BairlyMN"
                              : "BairlyMN — Үл хөдлөх хөрөнгийн зах зээл";
    }

    <title>@fullTitle</title>
    <meta name="description" content="@pageDescription" />

    <meta property="og:title" content="@fullTitle" />
    <meta property="og:description" content="@pageDescription" />
    <meta property="og:image" content="@pageImage" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="mn_MN" />
    <meta property="og:site_name" content="BairlyMN" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@fullTitle" />
    <meta name="twitter:description" content="@pageDescription" />
    <meta name="twitter:image" content="@pageImage" />

    <link rel="icon" type="image/svg+xml" href="/img/favicon.svg" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/bairly.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="d-flex flex-column min-vh-100">

    <!-- ═══ NAVBAR ══════════════════════════════════════════════════ -->
    <nav class="navbar navbar-expand-lg sticky-top">
        <div class="container">

            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <i class="bi bi-house-heart-fill"></i>BairlyMN
            </a>

            <button class="navbar-toggler border-0" type="button"
                    data-bs-toggle="collapse" data-bs-target="#mainNav"
                    aria-label="Цэс нээх">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNav">

                <ul class="navbar-nav me-auto gap-1 py-2 py-lg-0">
                    <li class="nav-item">
                        <a class="nav-link fw-500" asp-controller="Listings" asp-action="Index">
                            <i class="bi bi-grid me-1"></i>Зарууд
                        </a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link fw-500 dropdown-toggle" href="#"
                               data-bs-toggle="dropdown">
                            <i class="bi bi-list-ul me-1"></i>Ангилал
                        </a>
                        <ul class="dropdown-menu shadow border-0 rounded-3">
                            <li>
                                <a class="dropdown-item"
                                       asp-controller="Listings" asp-action="Index"
                                       asp-route-PropertyType="1">
                                    <i class="bi bi-building text-success"></i>Орон сууц
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item"
                                       asp-controller="Listings" asp-action="Index"
                                       asp-route-PropertyType="2">
                                    <i class="bi bi-house-door text-success"></i>Байшин
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item"
                                       asp-controller="Listings" asp-action="Index"
                                       asp-route-PropertyType="3">
                                    <i class="bi bi-map text-success"></i>Газар
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item"
                                       asp-controller="Listings" asp-action="Index"
                                       asp-route-PropertyType="4">
                                    <i class="bi bi-briefcase text-success"></i>Оффис
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item"
                                       asp-controller="Listings" asp-action="Index"
                                       asp-route-PropertyType="5">
                                    <i class="bi bi-box-seam text-success"></i>Агуулах
                                </a>
                            </li>
                        </ul>
                    </li>
                    <!-- Агент болох link -->
                    <li class="nav-item">
                        <a class="nav-link fw-500" asp-controller="Agent" asp-action="Pricing">
                            <i class="bi bi-patch-check me-1 text-success"></i>Агент болох
                        </a>
                    </li>
                </ul>

                <div class="py-2 py-lg-0">
                    @await Html.PartialAsync("_LoginPartial")
                </div>
            </div>
        </div>
    </nav>

    <!-- ═══ TOAST ═══════════════════════════════════════════════════ -->
    <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index:9999">
        @if (TempData["Success"] != null)
        {
            <div class="toast show align-items-center text-white bg-success border-0 rounded-3 shadow">
                <div class="d-flex">
                    <div class="toast-body fw-500 d-flex align-items-center gap-2">
                        <i class="bi bi-check-circle-fill"></i>@TempData["Success"]
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto"
                            data-bs-dismiss="toast"></button>
                </div>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="toast show align-items-center text-white bg-danger border-0 rounded-3 shadow">
                <div class="d-flex">
                    <div class="toast-body fw-500 d-flex align-items-center gap-2">
                        <i class="bi bi-exclamation-circle-fill"></i>@TempData["Error"]
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto"
                            data-bs-dismiss="toast"></button>
                </div>
            </div>
        }
        @if (TempData["Info"] != null)
        {
            <div class="toast show align-items-center text-white border-0 rounded-3 shadow"
                 style="background:#0ea5e9">
                <div class="d-flex">
                    <div class="toast-body fw-500 d-flex align-items-center gap-2">
                        <i class="bi bi-info-circle-fill"></i>@TempData["Info"]
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto"
                            data-bs-dismiss="toast"></button>
                </div>
            </div>
        }
    </div>

    <!-- ═══ MAIN ═════════════════════════════════════════════════════ -->
    <main class="flex-grow-1">
        @RenderBody()
    </main>

    <!-- ═══ FOOTER ══════════════════════════════════════════════════ -->
    <footer class="mt-auto">
        <div class="container py-5">
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <i class="bi bi-house-heart-fill text-success fs-4"></i>
                        <span class="fw-800 text-white" style="font-size:1.2rem">BairlyMN</span>
                    </div>
                    <p class="text-white-50 small mb-0">
                        Монголын хамгийн том үл хөдлөх хөрөнгийн онлайн зах зээл.
                        Орон сууц, байшин, газраа хялбархан зар, худалдаж ав.
                    </p>
                </div>
                <div class="col-6 col-md-2">
                    <h6 class="fw-600 text-white mb-3">Холбоос</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-2">
                            <a class="text-white-50 text-decoration-none"
                               asp-controller="Listings" asp-action="Index">Бүх зарууд</a>
                        </li>
                        <li class="mb-2">
                            <a class="text-white-50 text-decoration-none"
                               asp-controller="Listings" asp-action="Create">Зар нэмэх</a>
                        </li>
                        <li class="mb-2">
                            <a class="text-white-50 text-decoration-none"
                               asp-controller="Agent" asp-action="Pricing">Агент болох</a>
                        </li>
                        <li class="mb-2">
                            <a class="text-white-50 text-decoration-none"
                               asp-controller="Profile" asp-action="Index">Профайл</a>
                        </li>
                    </ul>
                </div>
                <div class="col-6 col-md-2">
                    <h6 class="fw-600 text-white mb-3">Ангилал</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-2">
                            <a class="text-white-50 text-decoration-none"
                               asp-controller="Listings" asp-action="Index"
                               asp-route-PropertyType="1">Орон сууц</a>
                        </li>
                        <li class="mb-2">
                            <a class="text-white-50 text-decoration-none"
                               asp-controller="Listings" asp-action="Index"
                               asp-route-PropertyType="2">Байшин</a>
                        </li>
                        <li class="mb-2">
                            <a class="text-white-50 text-decoration-none"
                               asp-controller="Listings" asp-action="Index"
                               asp-route-PropertyType="3">Газар</a>
                        </li>
                        <li class="mb-2">
                            <a class="text-white-50 text-decoration-none"
                               asp-controller="Listings" asp-action="Index"
                               asp-route-PropertyType="4">Оффис</a>
                        </li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h6 class="fw-600 text-white mb-3">Холбоо барих</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-2 text-white-50">
                            <i class="bi bi-envelope me-2 text-success"></i>info@bairly.mn
                        </li>
                        <li class="mb-2 text-white-50">
                            <i class="bi bi-telephone me-2 text-success"></i>+976 90096668
                        </li>
                        <li class="mb-2 text-white-50">
                            <i class="bi bi-geo-alt me-2 text-success"></i>23-р хороо, ХУД, Улаанбаатар, Монгол
                        </li>
                    </ul>
                    <div class="d-flex gap-2 mt-3">
                        <a href="#" class="btn btn-sm btn-outline-success rounded-circle"
                               style="width:34px;height:34px;display:flex;align-items:center;justify-content:center">
                            <i class="bi bi-facebook" style="font-size:13px"></i>
                        </a>
                        <a href="#" class="btn btn-sm btn-outline-success rounded-circle"
                               style="width:34px;height:34px;display:flex;align-items:center;justify-content:center">
                            <i class="bi bi-instagram" style="font-size:13px"></i>
                        </a>
                    </div>
                </div>
            </div>
            <hr class="border-secondary mt-4" />
            <p class="text-center text-white-50 small mb-0">
                &copy; @DateTime.Now.Year BairlyMN. Бүх эрх хуулиар хамгаалагдсан.
            </p>
        </div>
    </footer>

    <!-- ═══ SCRIPTS ══════════════════════════════════════════════════ -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="~/js/bairly.js" asp-append-version="true"></script>
    <script src="~/js/location-picker.js" asp-append-version="true"></script>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <script>
            const notifConn = new signalR.HubConnectionBuilder()
            .withUrl('/hubs/chat')
            .withAutomaticReconnect()
            .build();

            notifConn.on('ConversationUpdated', () => refreshBadge());
            notifConn.on('ReceiveMessage', msg => {
            if (msg.senderId !== '@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value')
            refreshBadge();
            });

            async function refreshBadge() {
            try {
            const r = await fetch('/Chat/UnreadCount');
            if (!r.ok) return;
            const d = await r.json();
            const count = d.count || 0;
            ['chatBadge','chatBadgeMenu'].forEach(id => {
            const el = document.getElementById(id);
            if (!el) return;
            el.textContent = count > 9 ? '9+' : count;
            el.classList.toggle('d-none', count === 0);
            });
            } catch {}
            }

            notifConn.start().then(() => refreshBadge()).catch(console.error);
            setInterval(refreshBadge, 60000);
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
