<!DOCTYPE html>
<html lang="mn">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — BairlyMN</title>

    <link rel="icon" type="image/svg+xml" href="/img/favicon.svg" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/bairly.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/chat.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body style="overflow:hidden">

    <!-- ═══ NAVBAR ══════════════════════════════════════════════════ -->
    <nav class="navbar navbar-expand-lg sticky-top">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <i class="bi bi-house-heart-fill"></i>BairlyMN
            </a>
            <button class="navbar-toggler border-0" type="button"
                    data-bs-toggle="collapse" data-bs-target="#mainNav"
                    aria-label="Цэс нээх">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto gap-1 py-2 py-lg-0">
                    <li class="nav-item">
                        <a class="nav-link fw-500" asp-controller="Listings" asp-action="Index">
                            <i class="bi bi-grid me-1"></i>Зарууд
                        </a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link fw-500 dropdown-toggle" href="#"
                               data-bs-toggle="dropdown">
                            <i class="bi bi-list-ul me-1"></i>Ангилал
                        </a>
                        <ul class="dropdown-menu shadow border-0 rounded-3">
                            <li>
                                <a class="dropdown-item" asp-controller="Listings"
                                       asp-action="Index" asp-route-PropertyType="1">
                                    <i class="bi bi-building text-success"></i>Орон сууц
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" asp-controller="Listings"
                                       asp-action="Index" asp-route-PropertyType="2">
                                    <i class="bi bi-house-door text-success"></i>Байшин
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" asp-controller="Listings"
                                       asp-action="Index" asp-route-PropertyType="3">
                                    <i class="bi bi-map text-success"></i>Газар
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" asp-controller="Listings"
                                       asp-action="Index" asp-route-PropertyType="4">
                                    <i class="bi bi-briefcase text-success"></i>Оффис
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" asp-controller="Listings"
                                       asp-action="Index" asp-route-PropertyType="5">
                                    <i class="bi bi-box-seam text-success"></i>Агуулах
                                </a>
                            </li>
                        </ul>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link fw-500" asp-controller="Agent" asp-action="Pricing">
                            <i class="bi bi-patch-check me-1 text-success"></i>Агент болох
                        </a>
                    </li>
                </ul>
                <div class="py-2 py-lg-0">
                    @await Html.PartialAsync("_LoginPartial")
                </div>
            </div>
        </div>
    </nav>

    <!-- ═══ TOAST ═══════════════════════════════════════════════════ -->
    <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index:9999">
        @if (TempData["Success"] != null)
        {
            <div class="toast show align-items-center text-white bg-success border-0 rounded-3 shadow">
                <div class="d-flex">
                    <div class="toast-body fw-500 d-flex align-items-center gap-2">
                        <i class="bi bi-check-circle-fill"></i>@TempData["Success"]
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto"
                            data-bs-dismiss="toast"></button>
                </div>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="toast show align-items-center text-white bg-danger border-0 rounded-3 shadow">
                <div class="d-flex">
                    <div class="toast-body fw-500 d-flex align-items-center gap-2">
                        <i class="bi bi-exclamation-circle-fill"></i>@TempData["Error"]
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto"
                            data-bs-dismiss="toast"></button>
                </div>
            </div>
        }
    </div>

    <!-- ═══ CHAT BODY ════════════════════════════════════════════════ -->
    <div style="height:calc(100vh - 66px);overflow:hidden">
        @RenderBody()
    </div>

    <!-- ═══ SCRIPTS ══════════════════════════════════════════════════ -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="~/js/bairly.js" asp-append-version="true"></script>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <script>
            const notifConn = new signalR.HubConnectionBuilder()
            .withUrl('/hubs/chat')
            .withAutomaticReconnect()
            .build();

            notifConn.on('ConversationUpdated', () => refreshBadge());
            notifConn.on('ReceiveMessage', msg => {
            if (msg.senderId !== '@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value')
            refreshBadge();
            });

            async function refreshBadge() {
            try {
            const r = await fetch('/Chat/UnreadCount');
            if (!r.ok) return;
            const d = await r.json();
            const count = d.count || 0;
            ['chatBadge','chatBadgeMenu'].forEach(id => {
            const el = document.getElementById(id);
            if (!el) return;
            el.textContent = count > 9 ? '9+' : count;
            el.classList.toggle('d-none', count === 0);
            });
            } catch {}
            }

            notifConn.start().then(() => refreshBadge()).catch(console.error);
            setInterval(refreshBadge, 60000);
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>