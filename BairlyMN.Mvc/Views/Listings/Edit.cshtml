@model ListingEditViewModel
@{ ViewData["Title"] = "Зар засах"; }

<div class="bg-light py-3 border-bottom mb-4">
    <div class="container">
        <nav><ol class="breadcrumb mb-0 small">
            <li class="breadcrumb-item">
                <a asp-controller="Home" asp-action="Index" class="text-success">Нүүр</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-controller="Listings" asp-action="Details"
                   asp-route-id="@Model.Id" class="text-success">Зар</a>
            </li>
            <li class="breadcrumb-item active">Засах</li>
        </ol></nav>
    </div>
</div>

<div class="container pb-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header p-4"
                     style="background:linear-gradient(135deg,#1d4ed8,#3b82f6)">
                    <h4 class="fw-700 text-white mb-0">
                        <i class="bi bi-pencil-square me-2"></i>Зар засах
                    </h4>
                    <p class="text-white opacity-75 small mb-0 mt-1">
                        Зарын мэдээллийг шинэчлэнэ үү
                    </p>
                </div>

                <div class="card-body p-4 p-md-5">
                    <form asp-action="Edit" asp-route-id="@Model.Id"
                          method="post" enctype="multipart/form-data" novalidate>
                        @Html.AntiForgeryToken()

                        <!-- ═══ STEP 1 ══════════════════════════════════════ -->
                        <div class="step-section mb-5">
                            <div class="d-flex align-items-center gap-3 mb-4">
                                <div class="step-num">1</div>
                                <div>
                                    <h5 class="fw-700 mb-0">Үндсэн мэдээлэл</h5>
                                    <small class="text-muted">Гарчиг, тайлбар, үнэ</small>
                                </div>
                            </div>

                            <div class="mb-4">
                                <label asp-for="Title" class="form-label fw-600">
                                    Гарчиг <span class="text-danger">*</span>
                                </label>
                                <input asp-for="Title" class="form-control rounded-3" />
                                <span asp-validation-for="Title" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <div class="mb-4">
                                <label asp-for="Description" class="form-label fw-600">
                                    Тайлбар <span class="text-danger">*</span>
                                </label>
                                <textarea asp-for="Description"
                                          class="form-control rounded-3" rows="5"></textarea>
                                <span asp-validation-for="Description" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label asp-for="PropertyType" class="form-label fw-600">
                                        Үл хөдлөхийн төрөл <span class="text-danger">*</span>
                                    </label>
                                    <select asp-for="PropertyType"
                                            class="form-select rounded-3"
                                            onchange="switchDetails(this.value)">
                                        <option value="1">🏢 Орон сууц</option>
                                        <option value="2">🏠 Байшин</option>
                                        <option value="3">🗺️ Газар</option>
                                        <option value="4">💼 Оффис</option>
                                        <option value="5">📦 Агуулах</option>
                                        <option value="6">📋 Бусад</option>
                                    </select>
                                    <span asp-validation-for="PropertyType" class="text-danger small mt-1 d-block"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="TransactionType" class="form-label fw-600">
                                        Гүйлгээний төрөл <span class="text-danger">*</span>
                                    </label>
                                    <select asp-for="TransactionType" class="form-select rounded-3">
                                        <option value="1">💰 Худалдах</option>
                                        <option value="2">🔑 Түрээслэх</option>
                                    </select>
                                    <span asp-validation-for="TransactionType" class="text-danger small mt-1 d-block"></span>
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="Price" class="form-label fw-600">
                                        Үнэ (₮) <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <input asp-for="Price" type="number"
                                               class="form-control rounded-start-3" min="0" />
                                        <span class="input-group-text rounded-end-3 bg-light fw-600">₮</span>
                                    </div>
                                    <span asp-validation-for="Price" class="text-danger small mt-1 d-block"></span>
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="Area" class="form-label fw-600">Талбай (м²)</label>
                                    <div class="input-group">
                                        <input asp-for="Area" type="number"
                                               class="form-control rounded-start-3"
                                               step="0.1" min="0" />
                                        <span class="input-group-text rounded-end-3 bg-light fw-600">м²</span>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="CategoryId" class="form-label fw-600">Ангилал</label>
                                    <select asp-for="CategoryId"
                                            asp-items="Model.Categories"
                                            class="form-select rounded-3">
                                        <option value="">— Сонгоно уу —</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <!-- STEP 2: Байршил -->
                            <div class="step-section mb-5">
                                <div class="step-header">
                                    <div class="step-num">2</div>
                                    <div>
                                        <h5 class="fw-700 mb-0">Байршил</h5>
                                        <small class="text-muted">
                                            Хот/Аймаг → Дүүрэг/Сум → Хороо/Баг
                                        </small>
                                    </div>
                                </div>

                                @await Html.PartialAsync("_LocationPicker", new BairlyMN.Mvc.ViewModels.LocationPickerModel
                                {
                                    Prefix     = "edit",
                                    SelectedId = Model.LocationNodeId,
                                    ShowLabel  = true
                                })

                                <div class="mt-3">
                                    <label asp-for="Address" class="form-label fw-600">
                                        Дэлгэрэнгүй хаяг
                                    </label>
                                    <input asp-for="Address"
                                           class="form-control rounded-3"
                                           placeholder="Гудамж, байр, тоот дугаар..." />
                                </div>
                            </div>

                           

                        <!-- ═══ STEP 3: Дэлгэрэнгүй мэдээлэл ════════════════ -->
                        <div class="step-section mb-5">
                            <div class="d-flex align-items-center gap-3 mb-4">
                                <div class="step-num">3</div>
                                <div>
                                    <h5 class="fw-700 mb-0">Дэлгэрэнгүй мэдээлэл</h5>
                                    <small class="text-muted">Үл хөдлөхийн төрлийн нэмэлт мэдээлэл</small>
                                </div>
                            </div>

                            <!-- Apartment -->
                            <div id="aptSection" class="d-none detail-section">
                                <div class="p-4 bg-light rounded-4">
                                    <h6 class="fw-700 mb-3 text-success">
                                        <i class="bi bi-building me-2"></i>Орон сууцны мэдээлэл
                                    </h6>
                                    <div class="row g-3">
                                        <div class="col-6 col-md-3">
                                            <label class="form-label fw-600 small">Давхар</label>
                                            <input name="ApartmentDetails.Floor" type="number" min="1"
                                                   class="form-control rounded-3"
                                                   value="@Model.ApartmentDetails?.Floor" />
                                        </div>
                                        <div class="col-6 col-md-3">
                                            <label class="form-label fw-600 small">Нийт давхар</label>
                                            <input name="ApartmentDetails.TotalFloors" type="number" min="1"
                                                   class="form-control rounded-3"
                                                   value="@Model.ApartmentDetails?.TotalFloors" />
                                        </div>
                                        <div class="col-6 col-md-3">
                                            <label class="form-label fw-600 small">Өрөөний тоо</label>
                                            <input name="ApartmentDetails.Rooms" type="number" min="1"
                                                   class="form-control rounded-3"
                                                   value="@Model.ApartmentDetails?.Rooms" />
                                        </div>
                                        <div class="col-6 col-md-3">
                                            <label class="form-label fw-600 small">Баригдсан он</label>
                                            <input name="ApartmentDetails.BuildYear"
                                                   type="number" min="1960" max="2030"
                                                   class="form-control rounded-3"
                                                   value="@Model.ApartmentDetails?.BuildYear" />
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label fw-600 small">Нөхцөл байдал</label>
                                            <select name="ApartmentDetails.Condition"
                                                    class="form-select rounded-3">
                                                <option value="">— Сонгоно уу —</option>
                                                @foreach (var c in new[]{"Шинэ","Сайн","Засварласан","Дунд зэрэг","Засвар хийгдэх шаардлагатай"})
                                                {
                                                   <option value="@c" selected="@(Model.ApartmentDetails?.Condition == c)">@c</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="col-12">
                                            <div class="d-flex flex-wrap gap-3">
                                                <div class="form-check form-check-inline">
                                                    <input name="ApartmentDetails.HasBalcony"
                                                           type="checkbox" class="form-check-input"
                                                           id="chkBalcony" value="true"
                                                           @(Model.ApartmentDetails?.HasBalcony == true ? "checked":"") />
                                                    <label class="form-check-label" for="chkBalcony">🏗️ Тагт</label>
                                                </div>
                                                <div class="form-check form-check-inline">
                                                    <input name="ApartmentDetails.HasParking"
                                                           type="checkbox" class="form-check-input"
                                                           id="chkParking" value="true"
                                                           @(Model.ApartmentDetails?.HasParking == true ? "checked":"") />
                                                    <label class="form-check-label" for="chkParking">🅿️ Зогсоол</label>
                                                </div>
                                                <div class="form-check form-check-inline">
                                                    <input name="ApartmentDetails.HasElevator"
                                                           type="checkbox" class="form-check-input"
                                                           id="chkElevator" value="true"
                                                           @(Model.ApartmentDetails?.HasElevator == true ? "checked":"") />
                                                    <label class="form-check-label" for="chkElevator">🛗 Лифт</label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- House -->
                            <div id="houseSection" class="d-none detail-section">
                                <div class="p-4 bg-light rounded-4">
                                    <h6 class="fw-700 mb-3 text-success">
                                        <i class="bi bi-house-door me-2"></i>Байшингийн мэдээлэл
                                    </h6>
                                    <div class="row g-3">
                                        <div class="col-6 col-md-3">
                                            <label class="form-label fw-600 small">Өрөөний тоо</label>
                                            <input name="HouseDetailsVM.Rooms" type="number" min="1"
                                                   class="form-control rounded-3"
                                                   value="@Model.HouseDetailsVM?.Rooms" />
                                        </div>
                                        <div class="col-6 col-md-3">
                                            <label class="form-label fw-600 small">Давхар</label>
                                            <input name="HouseDetailsVM.Floors" type="number" min="1"
                                                   class="form-control rounded-3"
                                                   value="@Model.HouseDetailsVM?.Floors" />
                                        </div>
                                        <div class="col-6 col-md-3">
                                            <label class="form-label fw-600 small">Газрын талбай (м²)</label>
                                            <input name="HouseDetailsVM.LandArea" type="number" step="0.1"
                                                   class="form-control rounded-3"
                                                   value="@Model.HouseDetailsVM?.LandArea" />
                                        </div>
                                        <div class="col-6 col-md-3">
                                            <label class="form-label fw-600 small">Баригдсан он</label>
                                            <input name="HouseDetailsVM.BuildYear"
                                                   type="number" min="1960" max="2030"
                                                   class="form-control rounded-3"
                                                   value="@Model.HouseDetailsVM?.BuildYear" />
                                        </div>
                                        <div class="col-12">
                                            <div class="d-flex flex-wrap gap-3">
                                                <div class="form-check form-check-inline">
                                                    <input name="HouseDetailsVM.HasGarage"
                                                           type="checkbox" class="form-check-input"
                                                           id="chkGarage" value="true"
                                                           @(Model.HouseDetailsVM?.HasGarage == true ? "checked":"") />
                                                    <label class="form-check-label" for="chkGarage">🚗 Гараж</label>
                                                </div>
                                                <div class="form-check form-check-inline">
                                                    <input name="HouseDetailsVM.HasGarden"
                                                           type="checkbox" class="form-check-input"
                                                           id="chkGarden" value="true"
                                                           @(Model.HouseDetailsVM?.HasGarden == true ? "checked":"") />
                                                    <label class="form-check-label" for="chkGarden">🌿 Цэцэрлэг</label>
                                                </div>
                                                <div class="form-check form-check-inline">
                                                    <input name="HouseDetailsVM.HasFence"
                                                           type="checkbox" class="form-check-input"
                                                           id="chkFence" value="true"
                                                           @(Model.HouseDetailsVM?.HasFence == true ? "checked":"") />
                                                    <label class="form-check-label" for="chkFence">🏗️ Хашаа</label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Land -->
                            <div id="landSection" class="d-none detail-section">
                                <div class="p-4 bg-light rounded-4">
                                    <h6 class="fw-700 mb-3 text-success">
                                        <i class="bi bi-map me-2"></i>Газрын мэдээлэл
                                    </h6>
                                    <div class="row g-3">
                                        <div class="col-md-4">
                                            <label class="form-label fw-600 small">Бүсчлэлийн төрөл</label>
                                            <select name="LandDetailsVM.ZoningType"
                                                    class="form-select rounded-3">
                                                <option value="">— Сонгоно уу —</option>
                                                @foreach (var z in new[]{"Орон сууцны","Үйлдвэрлэлийн","Хөдөө аж ахуйн","Арилжааны","Нийтийн"})
                                                {
                                                    <option value="@z"
                                                            selected=@(Model.LandDetailsVM?.ZoningType == z ? "selected":"")>@z</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label fw-600 small">Кадастрын дугаар</label>
                                            <input name="LandDetailsVM.CadastralNumber"
                                                   class="form-control rounded-3"
                                                   value="@Model.LandDetailsVM?.CadastralNumber" />
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label fw-600 small">Газрын зориулалт</label>
                                            <input name="LandDetailsVM.LandUsePurpose"
                                                   class="form-control rounded-3"
                                                   value="@Model.LandDetailsVM?.LandUsePurpose" />
                                        </div>
                                        <div class="col-12">
                                            <div class="d-flex flex-wrap gap-3">
                                                <div class="form-check form-check-inline">
                                                    <input name="LandDetailsVM.HasRoadAccess"
                                                           type="checkbox" class="form-check-input"
                                                           id="chkRoad" value="true"
                                                           @(Model.LandDetailsVM?.HasRoadAccess == true ? "checked":"") />
                                                    <label class="form-check-label" for="chkRoad">🛣️ Замтай</label>
                                                </div>
                                                <div class="form-check form-check-inline">
                                                    <input name="LandDetailsVM.HasElectricity"
                                                           type="checkbox" class="form-check-input"
                                                           id="chkElec" value="true"
                                                           @(Model.LandDetailsVM?.HasElectricity == true ? "checked":"") />
                                                    <label class="form-check-label" for="chkElec">⚡ Цахилгаантай</label>
                                                </div>
                                                <div class="form-check form-check-inline">
                                                    <input name="LandDetailsVM.HasWater"
                                                           type="checkbox" class="form-check-input"
                                                           id="chkWater" value="true"
                                                           @(Model.LandDetailsVM?.HasWater == true ? "checked":"") />
                                                    <label class="form-check-label" for="chkWater">💧 Усны хангамжтай</label>
                                                </div>
                                                <div class="form-check form-check-inline">
                                                    <input name="LandDetailsVM.HasSewer"
                                                           type="checkbox" class="form-check-input"
                                                           id="chkSewer" value="true"
                                                           @(Model.LandDetailsVM?.HasSewer == true ? "checked":"") />
                                                    <label class="form-check-label" for="chkSewer">🚰 Бохир усны систем</label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div id="noTypeMsg" class="text-center py-3 text-muted d-none">
                                <p class="small">Үл хөдлөхийн төрлийг сонгосны дараа нэмэлт мэдээлэл гарна</p>
                            </div>
                        </div>

                        <!-- ═══ STEP 4: Зургууд ══════════════════════════════ -->
                        <div class="step-section mb-5">
                            <div class="d-flex align-items-center gap-3 mb-4">
                                <div class="step-num">4</div>
                                <div>
                                    <h5 class="fw-700 mb-0">Зургууд</h5>
                                    <small class="text-muted">Одоогийн зургуудыг устгах эсвэл шинэ нэмэх</small>
                                </div>
                            </div>

                            @if (Model.ExistingImages.Any())
                            {
                                <div class="mb-4">
                                    <label class="form-label fw-600">
                                        Одоогийн зургууд
                                        <small class="text-muted fw-400">
                                            — устгахыг хүссэн зургийнхаа дээрх ✕ дарна уу
                                        </small>
                                    </label>
                                    <div class="d-flex flex-wrap gap-3">
                                        @foreach (var img in Model.ExistingImages)
                                        {
                                            <div class="position-relative img-thumb-wrapper"
                                                 style="width:110px;height:80px">
                                                <img src="@img.ImagePath"
                                                     class="w-100 h-100 rounded-3"
                                                     style="object-fit:cover"
                                                     onerror="this.src='/img/no-image.svg'" />
                                                <label class="position-absolute top-0 end-0 m-1"
                                                       style="cursor:pointer">
                                                    <input type="checkbox"
                                                           name="ImageIdsToDelete"
                                                           value="@img.Id"
                                                           class="d-none img-delete-check"
                                                           onchange="toggleDeleteMark(this)" />
                                                    <span class="badge bg-danger rounded-circle"
                                                          style="font-size:14px;line-height:1;
                                                                 width:22px;height:22px;
                                                                 display:flex;align-items:center;
                                                                 justify-content:center">
                                                        ✕
                                                    </span>
                                                </label>
                                            </div>
                                        }
                                    </div>
                                    <small class="text-muted d-block mt-2">
                                        <i class="bi bi-info-circle me-1"></i>
                                        ✕ дарсан зургууд хадгалахад устгагдана
                                    </small>
                                </div>
                            }

                            <div class="image-upload-area"
                                 onclick="document.getElementById('newImgInput').click()">
                                <i class="bi bi-cloud-arrow-up fs-2 text-success d-block mb-2"></i>
                                <p class="fw-600 mb-1">Шинэ зургууд нэмэх</p>
                                <p class="text-muted small mb-2">.jpg .png .webp</p>
                                <span class="btn btn-outline-success btn-sm rounded-pill px-3">
                                    <i class="bi bi-images me-2"></i>Зураг сонгох
                                </span>
                                <input type="file" name="Images"
                                       id="newImgInput" multiple
                                       accept="image/jpeg,image/png,image/webp"
                                       class="d-none"
                                       onchange="previewImages(this)" />
                            </div>

                            <div id="imgPreview" class="d-flex flex-wrap gap-2 mt-3"></div>
                        </div>

                        <!-- ═══ Submit ════════════════════════════════════════ -->
                        <div class="d-flex flex-column flex-md-row gap-3
                                    justify-content-between pt-4 border-top">
                            <button type="button"
                                    class="btn btn-outline-danger rounded-pill px-4"
                                    onclick="confirmDelete(@Model.Id)">
                                <i class="bi bi-trash me-2"></i>Зарыг устгах
                            </button>
                            <div class="d-flex gap-3">
                                <a asp-controller="Listings" asp-action="Details"
                                   asp-route-id="@Model.Id"
                                   class="btn btn-light rounded-pill px-4">
                                    Болих
                                </a>
                                <button type="submit"
                                        class="btn btn-primary rounded-pill px-5 fw-700 py-2">
                                    <i class="bi bi-check me-2"></i>Шинэчлэх
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete confirm modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow-xl">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-700">
                    <i class="bi bi-exclamation-triangle-fill text-danger me-2"></i>
                    Зар устгах
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted">
                    Та энэ зарыг бүрмөсөн устгахдаа итгэлтэй байна уу?
                    Энэ үйлдлийг буцааж болохгүй.
                </p>
            </div>
            <div class="modal-footer border-0">
                <button class="btn btn-light rounded-pill px-4"
                        data-bs-dismiss="modal">Болих</button>
                <form id="deleteForm" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger rounded-pill px-4 fw-600">
                        <i class="bi bi-trash me-2"></i>Устгах
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Styles {
<style>
.step-num {
    width: 36px; height: 36px;
    background: linear-gradient(135deg, #1d4ed8, #3b82f6);
    color: white; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 1rem; flex-shrink: 0;
}
.step-section { border-left: 3px solid #dbeafe; padding-left: 20px; }
.detail-section { animation: fadeInUp 0.3s ease; }
.img-thumb-wrapper img { transition: opacity .2s; }
.img-thumb-wrapper:has(.img-delete-check:checked) img { opacity: 0.35; }
</style>
}

 @section Scripts {
                            <partial name="_ValidationScriptsPartial" />
                            <script src="~/js/location-picker.js" asp-append-version="true"></script>
                            <script>
                            document.addEventListener('DOMContentLoaded', () => {
                                LocationPicker.init({
                                    prefix:     'edit',
                                    selectedId: @(Model.LocationNodeId?.ToString() ?? "null")
                                });
                            });
                          

function switchDetails(val) {
    document.querySelectorAll('.detail-section').forEach(el => el.classList.add('d-none'));
    document.getElementById('noTypeMsg').classList.add('d-none');
    const map = { '1': 'aptSection', '2': 'houseSection', '3': 'landSection' };
    const target = map[String(val)];
    if (target) {
        document.getElementById(target)?.classList.remove('d-none');
    } else {
        document.getElementById('noTypeMsg')?.classList.remove('d-none');
    }
}

