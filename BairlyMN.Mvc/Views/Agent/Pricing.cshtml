@* Views/Agent/Pricing.cshtml *@
@{
    ViewData["Title"] = "Агент болох";
}

<div class="bg-light py-2 py-md-3 border-bottom">
    <div class="container">
        <nav>
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item">
                    <a asp-controller="Home" asp-action="Index" class="text-success">Нүүр</a>
                </li>
                <li class="breadcrumb-item active">Агент болох</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container py-5">

    <!-- Hero -->
    <div class="text-center mb-5">
        <span class="badge bg-success rounded-pill px-3 py-2 mb-3"
              style="font-size:.8rem">
            <i class="bi bi-patch-check-fill me-1"></i>Агент програм
        </span>
        <h1 class="fw-800 mb-3" style="letter-spacing:-.5px">
            Илүү олон хүнд хүрч,<br class="d-none d-md-block" />
            илүү хурдан зараарай
        </h1>
        <p class="text-muted lead mb-0" style="max-width:520px;margin:0 auto">
            Агент эрхтэй болсноор таны зарууд хайлтын хамгийн дээрд гарч,
            онцгой "Агент" тэмдэгтэй харагдана.
        </p>
    </div>

    <!-- Benefits -->
    <div class="row g-4 mb-5 justify-content-center">
        @foreach (var (icon, color, title, desc) in new[] {
            ("bi-arrow-up-circle-fill", "#16a34a", "Дээр гарах",    "Таны зарууд хайлтын эхэнд байрлана"),
            ("bi-patch-check-fill",     "#2563eb", "Агент тэмдэг",  "Профайл болон зарын дэргэд онцгой тэмдэг харагдана"),
            ("bi-infinity",             "#7c3aed", "Хязгааргүй зар","Хэдэн зар ч байршуулж болно"),
            ("bi-telephone-fill",       "#0891b2", "Утас харагдах", "Таны утасны дугаар зарын хуудсанд харагдана"),
        })
        {
            <div class="col-6 col-md-3">
                <div class="text-center p-4 rounded-4 bg-white shadow-sm h-100">
                    <div class="rounded-circle d-inline-flex align-items-center
                        justify-content-center mb-3"
                         style="width:56px;height:56px;background:@(color)18">
                        <i class="bi @icon fs-4" style="color:@color"></i>
                    </div>
                    <h6 class="fw-700 mb-1">@title</h6>
                    <p class="text-muted small mb-0">@desc</p>
                </div>
            </div>
        }
    </div>

    <!-- Pricing cards -->
    <div class="row g-4 justify-content-center mb-5">

        <!-- 1 сар -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4 text-center">
                    <h5 class="fw-700 mb-1">1 сар</h5>
                    <div class="my-3">
                        <span class="fw-800" style="font-size:2rem;color:#16a34a">30,000</span>
                        <span class="text-muted">₮</span>
                    </div>
                    <p class="text-muted small mb-4">Туршиж үзэх хамгийн тохиромжтой</p>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <button class="btn btn-outline-success w-100 rounded-pill fw-600"
                                onclick="openRequestModal(1)">
                            Сонгох
                        </button>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login"
                               class="btn btn-outline-success w-100 rounded-pill fw-600">
                            Нэвтэрч сонгох
                        </a>
                    }
                </div>
            </div>
        </div>

        <!-- 3 сар — онцлох -->
        <div class="col-md-4">
            <div class="card border-0 rounded-4 h-100 position-relative"
                 style="background:linear-gradient(135deg,#166534,#16a34a);
                box-shadow:0 8px 32px rgba(22,163,74,.35)">
                <div class="position-absolute top-0 start-50 translate-middle">
                    <span class="badge rounded-pill px-3 py-2 fw-600"
                          style="background:#fbbf24;color:#78350f;font-size:.75rem">
                        ⭐ Хамгийн алдартай
                    </span>
                </div>
                <div class="card-body p-4 text-center text-white pt-5">
                    <h5 class="fw-700 mb-1">3 сар</h5>
                    <div class="my-3">
                        <span class="fw-800" style="font-size:2.2rem">75,000</span>
                        <span class="opacity-75">₮</span>
                    </div>
                    <p class="opacity-75 small mb-1">Сард ердөө 25,000₮</p>
                    <span class="badge rounded-pill mb-4"
                          style="background:rgba(255,255,255,.2);font-size:.72rem">
                        17% хэмнэлт
                    </span>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <button class="btn fw-700 w-100 rounded-pill d-block"
                                style="background:white;color:#16a34a"
                                onclick="openRequestModal(3)">
                            Сонгох
                        </button>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login"
                               class="btn fw-700 w-100 rounded-pill d-block"
                               style="background:white;color:#16a34a">
                            Нэвтэрч сонгох
                        </a>
                    }
                </div>
            </div>
        </div>

        <!-- 6 сар -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4 text-center">
                    <h5 class="fw-700 mb-1">6 сар</h5>
                    <div class="my-3">
                        <span class="fw-800" style="font-size:2rem;color:#16a34a">120,000</span>
                        <span class="text-muted">₮</span>
                    </div>
                    <p class="text-muted small mb-1">Сард ердөө 20,000₮</p>
                    <span class="badge bg-success-subtle text-success rounded-pill mb-4"
                          style="font-size:.72rem">
                        33% хэмнэлт
                    </span>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <button class="btn btn-outline-success w-100 rounded-pill fw-600"
                                onclick="openRequestModal(6)">
                            Сонгох
                        </button>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login"
                               class="btn btn-outline-success w-100 rounded-pill fw-600">
                            Нэвтэрч сонгох
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Төлбөрийн заавар -->
    <div class="card border-0 rounded-4 mb-5"
         style="background:linear-gradient(135deg,#f0fdf4,#dcfce7);
        border:1.5px solid #bbf7d0!important">
        <div class="card-body p-4">
            <h5 class="fw-700 mb-3">
                <i class="bi bi-credit-card-2-front text-success me-2"></i>
                Төлбөрийн заавар
            </h5>
            <div class="row g-3 align-items-center">
                <div class="col-md-8">
                    <div class="d-flex flex-column gap-2">
                        <div class="d-flex align-items-center gap-3 p-3 bg-white rounded-3 shadow-sm">
                            <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                                 style="width:44px;height:44px;background:#e0f2fe">
                                <i class="bi bi-bank text-primary fs-5"></i>
                            </div>
                            <div>
                                <div class="fw-700 small">Хаан банк</div>
                                <div class="fw-800 text-success" style="font-size:1.1rem;letter-spacing:1px">
                                    5909252474
                                </div>
                                <div class="text-muted small">Badrakh</div>
                            </div>
                            <button class="btn btn-sm btn-light rounded-pill ms-auto"
                                    onclick="copyAccount()"
                                    id="copyBtn">
                                <i class="bi bi-copy me-1"></i>Хуулах
                            </button>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <ol class="text-muted small mb-0 ps-3" style="line-height:1.9">
                        <li>Дээрх дансанд мөнгө шилжүүлнэ</li>
                        <li>"Агент болох" хүсэлт илгээнэ</li>
                        <li>Admin шилжүүлгийг шалгаад эрхийг нэмнэ</li>
                        <li>Chat-ээр мэдэгдэл ирнэ ✅</li>
                    </ol>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Request Modal -->
@if (User.Identity?.IsAuthenticated == true)
{
    <div class="modal fade" id="requestModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 rounded-4">
                <div class="modal-header border-0 pb-0">
                    <h5 class="fw-700 mb-0">
                        <i class="bi bi-send text-success me-2"></i>Агент болох хүсэлт
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <form asp-controller="Agent" asp-action="RequestAgent"
                      method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="months" id="modalMonths" value="3" />

                    <div class="modal-body pt-3">

                        <!-- Сонгосон хугацаа -->
                        <div class="p-3 rounded-3 mb-3"
                             style="background:#f0fdf4;border:1px solid #bbf7d0">
                            <div class="fw-600 small text-success mb-1">
                                <i class="bi bi-info-circle me-1"></i>Сонгосон хугацаа
                            </div>
                            <div class="fw-800" id="modalPlanText">3 сар — 75,000₮</div>
                        </div>

                        <!-- Данс -->
                        <div class="p-3 rounded-3 mb-3"
                             style="background:#eff6ff;border:1px solid #bfdbfe">
                            <div class="fw-600 small mb-2" style="color:#1d4ed8">
                                <i class="bi bi-bank me-1"></i>Төлбөр шилжүүлэх данс
                            </div>
                            <div class="fw-700">
                                Хаан банк: <span class="text-success">5909252474</span> (Badrakh)
                            </div>
                        </div>

                        <!-- Нэмэлт мессеж -->
                        <div class="mb-3">
                            <label class="form-label fw-600 small">
                                Нэмэлт мессеж
                                <span class="text-muted fw-400">(гүйлгээний дугаар гэх мэт)</span>
                            </label>
                            <textarea name="message" class="form-control rounded-3"
                                      rows="2"
                                      placeholder="Жишээ: Гүйлгээний дугаар: 123456789"></textarea>
                        </div>

                        <!-- Гүйлгээний зураг upload -->
                        <div class="mb-1">
                            <label class="form-label fw-600 small">
                                Гүйлгээний баримт
                                <span class="text-muted fw-400">(зураг оруулна уу)</span>
                            </label>

                            <div id="uploadArea"
                                 onclick="document.getElementById('receiptFile').click()"
                                 style="border:2px dashed #bbf7d0;border-radius:12px;
                                padding:20px;text-align:center;cursor:pointer;
                                background:#f0fdf4;transition:border-color .15s;
                                position:relative;">

                                <input type="file" name="receiptImage" id="receiptFile"
                                       accept="image/*" style="display:none"
                                       onchange="previewReceipt(event)" />

                                <!-- Placeholder -->
                                <div id="uploadPlaceholder">
                                    <i class="bi bi-cloud-upload text-success"
                                       style="font-size:2rem"></i>
                                    <div class="fw-600 text-success mt-2 small">
                                        Зураг оруулах
                                    </div>
                                    <div class="text-muted" style="font-size:.75rem">
                                        JPG, PNG · Дарж сонгоно уу
                                    </div>
                                </div>

                                <!-- Preview -->
                                <div id="uploadPreview"
                                     style="display:none;position:relative;
                                    pointer-events:none">
                                    <img id="previewImg"
                                         style="max-height:160px;max-width:100%;
                                    border-radius:8px;object-fit:contain;
                                    display:block;margin:0 auto" />
                                    <button type="button"
                                            onclick="removeReceipt(event)"
                                            style="position:absolute;top:-8px;right:-8px;
                                        width:26px;height:26px;border-radius:50%;
                                        background:#ef4444;border:none;color:white;
                                        font-size:.8rem;cursor:pointer;
                                        display:flex;align-items:center;
                                        justify-content:center;
                                        pointer-events:all">
                                        <i class="bi bi-x"></i>
                                    </button>
                                </div>
                            </div>
                        </div>

                    </div>

                    <div class="modal-footer border-0 pt-0">
                        <button type="button" class="btn btn-light rounded-pill px-4"
                                data-bs-dismiss="modal">
                            Болих
                        </button>
                        <button type="submit"
                                class="btn btn-success rounded-pill px-5 fw-700">
                            <i class="bi bi-send me-2"></i>Хүсэлт илгээх
                        </button>
                    </div>
                </form>

            </div>
        </div>
    </div>

    <script>
        const plans = {
            1: { text: "1 сар — 30,000₮" },
            3: { text: "3 сар — 75,000₮" },
            6: { text: "6 сар — 120,000₮" }
        };

        function openRequestModal(months) {
            document.getElementById('modalMonths').value = months;
            document.getElementById('modalPlanText').textContent = plans[months].text;
            // Зургийг цэвэрлэх
            removeReceiptSilent();
            new bootstrap.Modal(document.getElementById('requestModal')).show();
        }

        function previewReceipt(e) {
            const file = e.target.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = ev => {
                document.getElementById('previewImg').src = ev.target.result;
                document.getElementById('uploadPlaceholder').style.display = 'none';
                document.getElementById('uploadPreview').style.display = 'block';
                document.getElementById('uploadArea').style.borderColor = '#16a34a';
            };
            reader.readAsDataURL(file);
        }

        function removeReceipt(e) {
            e.stopPropagation();
            removeReceiptSilent();
        }

        function removeReceiptSilent() {
            const fi = document.getElementById('receiptFile');
            if (fi) fi.value = '';
            const pi = document.getElementById('previewImg');
            if (pi) pi.src = '';
            const ph = document.getElementById('uploadPlaceholder');
            if (ph) ph.style.display = 'block';
            const pv = document.getElementById('uploadPreview');
            if (pv) pv.style.display = 'none';
            const ua = document.getElementById('uploadArea');
            if (ua) ua.style.borderColor = '#bbf7d0';
        }

        function copyAccount() {
            navigator.clipboard.writeText('5909252474').then(() => {
                const btn = document.getElementById('copyBtn');
                btn.innerHTML = '<i class="bi bi-check-lg me-1"></i>Хуулагдлаа';
                btn.classList.replace('btn-light', 'btn-success');
                setTimeout(() => {
                    btn.innerHTML = '<i class="bi bi-copy me-1"></i>Хуулах';
                    btn.classList.replace('btn-success', 'btn-light');
                }, 2000);
            });
        }
    </script>
}