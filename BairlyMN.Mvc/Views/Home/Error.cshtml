@{
    ViewData["Title"] = "Алдаа гарлаа";
}

<div class="container py-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="mb-4">
                <i class="bi bi-exclamation-triangle-fill text-warning"
                   style="font-size:5rem"></i>
            </div>
            <h1 class="fw-800 mb-2" style="font-size:5rem;color:#e2e8f0">500</h1>
            <h3 class="fw-700 mb-2">Серверийн алдаа</h3>
            <p class="text-muted mb-4">
                Уучлаарай, ямар нэгэн алдаа гарлаа.
                Та дахин оролдоно уу.
            </p>
            <div class="d-flex gap-3 justify-content-center">
                <a asp-controller="Home" asp-action="Index"
                       class="btn btn-success rounded-pill px-5 fw-600">
                    <i class="bi bi-house me-2"></i>Нүүр хуудас
                </a>
                <button onclick="history.back()"
                        class="btn btn-light rounded-pill px-4 fw-600">
                    <i class="bi bi-arrow-left me-2"></i>Буцах
                </button>
            </div>
        </div>
    </div>
</div>