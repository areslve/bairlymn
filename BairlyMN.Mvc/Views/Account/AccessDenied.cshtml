@{
    ViewData["Title"] = "Хандах эрхгүй";
}

<div class="container py-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="mb-4">
                <i class="bi bi-shield-exclamation text-danger" style="font-size:5rem"></i>
            </div>
            <h2 class="fw-800 mb-2">Хандах эрхгүй</h2>
            <p class="text-muted mb-4">
                Та энэ хуудсанд хандах эрхгүй байна.
                Хэрэв алдаа гэж үзвэл администратортай холбоо барина уу.
            </p>
            <div class="d-flex gap-3 justify-content-center">
                <a asp-controller="Home" asp-action="Index"
                       class="btn btn-success rounded-pill px-4 fw-600">
                    <i class="bi bi-house me-2"></i>Нүүр хуудас
                </a>
                <a asp-controller="Account" asp-action="Login"
                       class="btn btn-outline-success rounded-pill px-4 fw-600">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Нэвтрэх
                </a>
            </div>
        </div>
    </div>
</div>